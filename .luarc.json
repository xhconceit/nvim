{
  "$schema": "https://raw.githubusercontent.com/LuaLS/vscode-lua/master/setting/schema.json",
  "runtime": {
    "version": "LuaJIT",
    "pathStrict": true
  },
  "workspace": {
    "library": [
      "/usr/local/nvim/share/nvim/runtime/lua",
      "/usr/local/nvim/share/nvim/runtime/lua/vim/lsp",
      "${workspaceFolder}/lua",
      "${3rd}/luv/library"
    ],
    "ignoreDir": [".git"],
    "checkThirdParty": false
  }
}
